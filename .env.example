# 複製這份成 .env 並填入真實值，用於本機測試。
# 絕對不要 commit .env（.gitignore 已擋）。
#
# 在 Render 上線時，這些要在 Render Dashboard 的 Environment 頁面設定。

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxx

# Flask session 加密 key — 可以用 `python -c "import secrets; print(secrets.token_hex(32))"` 產生
FLASK_SECRET_KEY=change-me-to-a-random-64-char-hex-string

# 可選：上線後是否要求登入才能看首頁
PRIVATE_MODE=false

# 可選：是否允許自助註冊（false 比較安全）
ALLOW_REGISTRATION=false
